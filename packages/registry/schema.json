{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UI8Kit Configuration",
  "description": "Configuration file for ui8kit CLI (UI8Kit structure)",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema URL"
    },
    "framework": {
      "type": "string",
      "enum": [
        "vite-react"
      ],
      "description": "Target framework"
    },
    "typescript": {
      "type": "boolean",
      "default": true,
      "description": "Whether the project uses TypeScript"
    },
    "globalCss": {
      "type": "string",
      "default": "src/index.css",
      "description": "Path to global styles entry file"
    },
    "aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {
        "@": "./src",
        "@/components": "./src/components",
        "@/ui": "./src/components/ui",
        "@/layouts": "./src/layouts",
        "@/blocks": "./src/blocks",
        "@/lib": "./src/lib",
        "@/variants": "./src/variants"
      },
      "description": "Path aliases for imports in UI8Kit structure"
    },
    "registry": {
      "type": "string",
      "default": "@ui8kit",
      "description": "Default component registry"
    },
    "componentsDir": {
      "type": "string",
      "default": "./src/components",
      "description": "Directory where utility components will be installed"
    },
    "libDir": {
      "type": "string",
      "default": "./src/lib",
      "description": "Directory for utility libraries"
    },
    "registryUrl": {
      "type": "string",
      "description": "Explicit registry URL override"
    },
    "registryVersion": {
      "type": "string",
      "description": "Registry version"
    },
    "strictCdn": {
      "type": "boolean",
      "default": false,
      "description": "Disable fallback to built-in CDN URLs"
    },
    "importStyle": {
      "type": "string",
      "enum": [
        "alias",
        "package"
      ],
      "default": "alias",
      "description": "How component imports are rewritten: alias or package"
    }
  },
  "required": [
    "framework"
  ],
  "additionalProperties": false
}