{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UI8Kit Registry",
  "description": "Registry schema for UI8Kit component system",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema URL"
    },
    "name": {
      "type": "string",
      "description": "Registry name"
    },
    "homepage": {
      "type": "string",
      "description": "Registry homepage URL"
    },
    "registry": {
      "type": "string",
      "enum": [
        "ui"
      ],
      "description": "Registry type (e.g., ui)"
    },
    "version": {
      "type": "string",
      "description": "Registry version"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ui",
          "composite",
          "components",
          "layouts",
          "lib",
          "blocks",
          "variants"
        ]
      },
      "description": "Available component categories"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "registry:lib",
              "registry:block",
              "registry:component",
              "registry:ui",
              "registry:composite",
              "registry:layout",
              "registry:variants"
            ]
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "type"
        ],
        "additionalProperties": false
      },
      "description": "Component metadata for quick lookup"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "https://ui.buildy.tw/schema/registry-item.json"
      },
      "description": "Full component definitions"
    }
  },
  "required": [
    "items"
  ],
  "additionalProperties": false
}